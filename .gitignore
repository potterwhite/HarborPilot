################################################################################
# HarborPilot .gitignore
#
# Last reviewed: 2026-06-26
#
# Sections:
#   1. IDE & Editor
#   2. OS Metadata
#   3. Offline Packages
#   4. Generated / Temporary Files
#   5. Build Logs
#   6. Docker Compose (generated by scripts)
#   7. Symlinks & Auto-created Directories
#   8. Serverside Build Artifacts
#   9. Build Output
#  10. Personal Notes
################################################################################


# =============================================================================
# 1. IDE & Editor
# =============================================================================

# VSCode — local workspace settings and extensions
.vscode/*


# =============================================================================
# 2. OS Metadata
# =============================================================================

# macOS Finder custom attributes (icon positions, tags, etc.)


# =============================================================================
# 3. Offline Packages
# =============================================================================
# Binary SDK packages are too large for git. Track only scripts and .gitkeep.

# Ignore everything in offline_packages …
**/offline_packages/**/*
# … but keep the directory structure
!**/offline_packages/
!**/offline_packages/**/
# … keep shell scripts (pull/push helpers)
!**/offline_packages/**/*.sh
# … keep .gitkeep (forces empty dirs into git)
!**/offline_packages/**/.gitkeep

# Keep .gitkeep files everywhere (ensures empty dirs survive git clone)
!**/.gitkeep


# =============================================================================
# 4. Generated / Temporary Files
# =============================================================================

# Temporary symlink created by build scripts (libs → stage directories)
# Created 2024-11 — recreated on each build, never commit
docker/dev-env-clientside/libs

# Stage 3 SDK configs — generated from templates at build time
# Created 2024-11 — only templates are tracked
docker/dev-env-clientside/stage_3_sdk/configs/*
!docker/dev-env-clientside/stage_3_sdk/configs/*_template

# install_sdk.sh — generated by SDK setup, per-platform
# Created 2024-11
docker/dev-env-clientside/stage_3_sdk/scripts/install_sdk.sh

# Stage 4/5 runtime configs — generated at container startup
# Created 2024-11 — values come from env layer system
docker/dev-env-clientside/stage_4_config/configs/env_config.conf
docker/dev-env-clientside/stage_5_final/configs/entrypoint.conf
docker/dev-env-clientside/stage_5_final/configs/workspace.conf


# =============================================================================
# 5. Build Logs
# =============================================================================
# Generated by each Dockerfile stage build. Never useful in git.

**/build_log.txt


# =============================================================================
# 6. Docker Compose (generated by scripts)
# =============================================================================
# Generated docker-compose.yaml files
**/docker-compose.yaml


# =============================================================================
# 7. Symlinks & Auto-created Directories
# =============================================================================

# Volume symlinks auto-created by scripts
**/volume


# =============================================================================
# 8. Serverside Build Artifacts
# =============================================================================
# Ignore everything in docker/dev-env-serverside except build scripts and modules.
# Created 2024-11 — serverside generates configs at build time

docker/dev-env-serverside/*
!docker/dev-env-serverside/build.sh
!docker/dev-env-serverside/new_build.sh
!docker/dev-env-serverside/old_build.sh
!docker/dev-env-serverside/dockerfile_modules
!docker/dev-env-serverside/dockerfile_modules/**


# =============================================================================
# 9. Build Output
# =============================================================================

# Handover packaging output (tarballs generated by ./harbor → Package Handover)
output/


# =============================================================================
# 10. Personal Notes
# =============================================================================
# Author's strategy/draft files — not part of the project

ASO_strategy.md
ASO_awesome_docker_pr.md
ASO_devto_article.md
ASO_devto_publish.sh
ASO_operations_manual.md
