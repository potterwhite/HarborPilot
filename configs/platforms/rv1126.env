################################################################################
# File: configs/platforms/rv1126.env
#
# Description: Platform-specific overrides for RV1126 (Ubuntu 22.04).
#              Only values that DIFFER from configs/defaults/*.env are listed.
#              All other settings are inherited from the defaults layer.
#
# Author: PotterWhite
# Created: 2024-11-21
# Last Modified: 2026-03-18
#
# Copyright (c) 2024 [PotterWhite]
# License: MIT
#
# Port offset: n8 base + 30
#   CLIENT_SSH_PORT=2139, SERVER_SSH_PORT=2140, GDB_PORT=2375
#
################################################################################

# =============================================================================
# Platform Identity  [REQUIRED — no defaults]
# =============================================================================
PRODUCT_NAME="rv1126"
OS_VERSION="22.04"

# Derived from PRODUCT_NAME (keep in sync)
IMAGE_NAME="${PRODUCT_NAME}-dev-env"
LATEST_IMAGE_TAG=${PROJECT_VERSION}
CONTAINER_NAME=${PRODUCT_NAME}

# =============================================================================
# Tools Overrides  [differs from defaults]
# =============================================================================
NPM_USE_CHINA_MIRROR="true"

# =============================================================================
# Registry  [inherited defaults: HAVE_GITLAB_SERVER=TRUE, IP=192.168.3.67, PORT=9000]
# =============================================================================
REGISTRY_URL="${UBUNTU_SERVER_IP}:${UBUNTU_SERVER_PORT}/team_${CONTAINER_NAME}"

# =============================================================================
# SDK  [derived — depends on CONTAINER_NAME]
# =============================================================================
SDK_INSTALL_PATH="${WORKSPACE_ROOT}/sdk"
SDK_GIT_REPO="git@${UBUNTU_SERVER_IP}:team_${CONTAINER_NAME}/${CONTAINER_NAME}_sdk.git"
SDK_GIT_KEY_FILE="SDK_${CONTAINER_NAME}_ED25519"
SDK_GIT_DEFAULT_BRANCH="main"

# =============================================================================
# Docker Volumes  [REQUIRED — no universal default]
# =============================================================================
HOST_VOLUME_DIR="/mnt/2tb_wd_purpleSurveillance_hdd/system-redirection/Development/docker/volumes/rv1126"

# =============================================================================
# Container Runtime  [REQUIRED — ports are platform-unique]
# =============================================================================
CLIENT_SSH_PORT="2139"
SERVER_SSH_PORT="2140"
GDB_PORT="2375"

# =============================================================================
# Serverside distcc  [same as n8 base — offset 0]
# =============================================================================
DISTCC_GCC_11_MAIN_PORT="3652"
DISTCC_GCC_11_STATS_PORT="3653"
DISTCC_GCC_10_MAIN_PORT="3642"
DISTCC_GCC_10_STATS_PORT="3643"

# =============================================================================
# Toolchain
# =============================================================================
TOOLCHAIN_TARBALL_NAME="gcc-arm-10.3-2021.07-x86_64-aarch64-none-linux-gnu.tar.gz"

# =============================================================================
# Serverside derived names
# =============================================================================
SERVERSIDE_IMAGE_NAME="${IMAGE_NAME}-serverside"
SERVERSIDE_CONTAINER_NAME="${CONTAINER_NAME}-serverside"

# =============================================================================
# Proxy Overrides  [differs from defaults: HAS_PROXY=false]
# =============================================================================
HAS_PROXY="true"
