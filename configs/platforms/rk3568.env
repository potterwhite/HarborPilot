################################################################################
# File: configs/platforms/rk3568.env
#
# Description: Platform-specific overrides for RK3568 (Ubuntu 20.04).
#              Only values that DIFFER from configs/defaults/*.env are listed.
#              All other settings are inherited from the defaults layer.
#
# Author: PotterWhite
# Created: 2024-11-21
# Last Modified: 2026-03-24
#
# Copyright (c) 2024 [PotterWhite]
# License: MIT
#
# Port: PORT_SLOT=2
#   → CLIENT_SSH_PORT=2129, GDB_PORT=2365 (auto-calculated)
#
################################################################################

# =============================================================================
# Platform Identity  [REQUIRED — no defaults]
# =============================================================================
PRODUCT_NAME="rk3568"
OS_DISTRIBUTION="ubuntu"
OS_VERSION="20.04"

# Derived from PRODUCT_NAME (keep in sync)
IMAGE_NAME="${PRODUCT_NAME}-dev-env"
LATEST_IMAGE_TAG=${PROJECT_VERSION}
CONTAINER_NAME=${PRODUCT_NAME}

# =============================================================================
# Tools Overrides  [differs from defaults]
# =============================================================================
NPM_USE_CHINA_MIRROR="true"

# =============================================================================
# GitLab Server  [optional]
# =============================================================================
HAVE_GITLAB_SERVER="TRUE"
GITLAB_SERVER_IP="192.168.3.67"
GITLAB_SERVER_PORT="80"

# =============================================================================
# Harbor Registry  [required for push/pull]
# =============================================================================
HARBOR_SERVER_IP="192.168.3.67"
HARBOR_SERVER_PORT="9000"
REGISTRY_URL="${HARBOR_SERVER_IP}:${HARBOR_SERVER_PORT}/team_${CHIP_FAMILY}"

# =============================================================================
# SDK  [CHIP_FAMILY defaults to PRODUCT_NAME — no override needed here]
# =============================================================================
SDK_INSTALL_PATH="${WORKSPACE_ROOT}/sdk"
SDK_GIT_REPO="git@${GITLAB_SERVER_IP}:team_${CHIP_FAMILY}/${CHIP_FAMILY}_sdk.git"
SDK_GIT_KEY_FILE="SDK_${CHIP_FAMILY}_ED25519"
SDK_GIT_DEFAULT_BRANCH="br_main_20250206"

# =============================================================================
# Docker Volumes  [REQUIRED — no universal default]
# =============================================================================
HOST_VOLUME_DIR="/mnt/2tb_wd_purpleSurveillance_hdd/system-redirection/Development/docker/volumes/rk3568"

# =============================================================================
# Container Runtime  [ports auto-calculated from PORT_SLOT]
# =============================================================================
PORT_SLOT="2"

# =============================================================================
# Proxy Overrides  [differs from defaults: HAS_PROXY=false]
# =============================================================================
HAS_PROXY="true"
