################################################################################
# File: configs/platforms/offline.env
#
# Description: Template / offline platform configuration.
#              Use this as the starting point for a new platform.
#              Only values that DIFFER from configs/defaults/*.env are listed.
#
# Author: PotterWhite
# Created: 2024-11-21
# Last Modified: 2026-03-18
#
# Copyright (c) 2024 [Your Company/Name]
# License: MIT
################################################################################

# =============================================================================
# Platform Identity  [REQUIRED — no defaults]
# =============================================================================
PRODUCT_NAME="template"
OS_VERSION="22.04"

# Derived from PRODUCT_NAME (keep in sync)
IMAGE_NAME="${PRODUCT_NAME}-dev-env"
LATEST_IMAGE_TAG=${PROJECT_VERSION}
CONTAINER_NAME=${PRODUCT_NAME}

# =============================================================================
# Tools Overrides
# =============================================================================
NPM_USE_CHINA_MIRROR="true"

# =============================================================================
# Registry Overrides  [offline: no servers]
# =============================================================================
HAVE_GITLAB_SERVER="FALSE"
HAVE_HARBOR_SERVER="FALSE"
REGISTRY_URL="${UBUNTU_SERVER_IP}:${UBUNTU_SERVER_PORT}/team_${CONTAINER_NAME}"

# =============================================================================
# SDK  [derived — depends on CONTAINER_NAME]
# =============================================================================
SDK_INSTALL_PATH="${WORKSPACE_ROOT}/sdk"
SDK_GIT_REPO="git@${UBUNTU_SERVER_IP}:team_${CONTAINER_NAME}/${CONTAINER_NAME}_sdk.git"
SDK_GIT_KEY_FILE="SDK_${CONTAINER_NAME}_ED25519"
SDK_GIT_DEFAULT_BRANCH="br_main_20250206"

# =============================================================================
# Docker Volumes  [REQUIRED — no universal default]
# =============================================================================
VOLUMES_ROOT="${WORKSPACE_ROOT}/docker_volumes"
HOST_VOLUME_DIR="/mnt/2tb_wd_purpleSurveillance_hdd/Development/docker/volumes/template"

# =============================================================================
# Container Runtime  [REQUIRED — ports are platform-unique]
# =============================================================================
CLIENT_SSH_PORT="2109"
SERVER_SSH_PORT="2110"
GDB_PORT="2345"

# =============================================================================

# =============================================================================
# Toolchain
# =============================================================================
TOOLCHAIN_TARBALL_NAME="gcc-arm-10.3-2021.07-x86_64-aarch64-none-linux-gnu.tar.gz"

# =============================================================================

# =============================================================================
# Proxy Overrides  [differs from defaults: HAS_PROXY=false]
# =============================================================================
HAS_PROXY="true"
