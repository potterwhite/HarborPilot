# =============================================================================
# Base Configuration (Defaults)
# =============================================================================
# PRODUCT_NAME is platform-specific — must be set in platform override file
# IMAGE_NAME, CONTAINER_NAME are derived from PRODUCT_NAME; override if needed
OS_DISTRIBUTION="ubuntu"
OS_VERSION="22.04"
# OS_VERSION with dots replaced by dashes — safe for use in PRODUCT_NAME / CONTAINER_NAME
# (docker compose project names forbid dots; image tags allow them but dash is consistent)
OS_VERSION_ID="22-04"
DEV_USERNAME="developer"
DEV_GROUP="developer"
DEV_USER_PASSWORD="123"
DEV_USER_ROOT_PASSWORD="123"
DEV_UID="1000"
DEV_GID="1000"
TIMEZONE="Asia/Hong_Kong"
DEBIAN_FRONTEND="noninteractive"
