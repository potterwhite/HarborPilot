################################################################################
# File: configs/defaults/runtime.env
#
# Description: Default container runtime configuration shared across all
#              platforms. Override specific values in platform override file.
#              Port numbers (CLIENT_SSH_PORT, GDB_PORT) are
#              always platform-specific — set via PORT_SLOT in the platform file.
#
# Author: PotterWhite
# Created: 2026-03-18
#
# Copyright (c) 2024 [PotterWhite]
# License: MIT
################################################################################

# =============================================================================
# Container Runtime Configuration (Defaults)
# =============================================================================
ENABLE_SSH="true"
# CLIENT_SSH_PORT: derived from PORT_SLOT via scripts/port_calc.sh
ENABLE_SYSLOG="true"
ENABLE_GDB_SERVER="true"
# GDB_PORT:        derived from PORT_SLOT via scripts/port_calc.sh
ENABLE_CORE_DUMPS="true"
CORE_PATTERN="${WORKSPACE_3RD_LOGS_SUBDIR}/core-%e-%p-%t"
USE_NVIDIA_GPU="false"
