# =============================================================================
# Docker Volumes Configuration (Defaults)
# =============================================================================
VOLUMES_ROOT="${WORKSPACE_ROOT}"
# HOST_VOLUME_DIR: the host path mounted into the container.
# This has no universal default — set it in configs/platforms/<platform>.env
# HOST_VOLUME_DIR="/path/to/your/host/volume"

# =============================================================================
# Extra volume mounts  [optional, 0..N per platform]
# =============================================================================
# Use EXTRA_VOLUME_0, EXTRA_VOLUME_1, … in your platform .env file to mount
# additional host directories into the container at runtime.
#
# Format:  EXTRA_VOLUME_N="<host_absolute_path>:<container_absolute_path>"
#
# Examples (in configs/platforms/<platform>.env):
#   EXTRA_VOLUME_0="/mnt/host-a:/volumes_container-a"
#   EXTRA_VOLUME_1="/mnt/data:/data"
#
# Rules:
#   - Indices MUST be contiguous starting from 0; scanning stops at the first
#     missing index.
#   - Omit all EXTRA_VOLUME_* lines if no extra mounts are needed.
#   - Do NOT define any EXTRA_VOLUME_* here in the defaults file; each
#     platform declares only what it needs.
#
# These are injected into docker-compose.yaml by 04_compose_generator.sh.
