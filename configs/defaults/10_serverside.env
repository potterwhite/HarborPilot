# =============================================================================
# Serverside Image & Container Options (Defaults)
# =============================================================================
ENABLE_SERVERSIDE="false"

DISTCC_GCC_11_ENABLE="true"
DISTCC_GCC_11_MAIN_PORT="3652"
DISTCC_GCC_11_STATS_PORT="3653"

DISTCC_GCC_10_ENABLE="true"
DISTCC_GCC_10_MAIN_PORT="3642"
DISTCC_GCC_10_STATS_PORT="3643"

DISTCC_LOG_LEVEL="debug"
DISTCC_LOG_DIR="${VOLUMES_ROOT}/log/distccd"

TOOLCHAIN_TARBALL_NAME="gcc-arm-10.3-2021.07-x86_64-aarch64-none-linux-gnu.tar.gz"
PYTHON_VERSION="3.10"
TOOLCHAIN_DIR="/opt/toolchains"
# SERVERSIDE_IMAGE_NAME and SERVERSIDE_CONTAINER_NAME are derived; override if needed
SERVERSIDE_IMAGE_NAME="${IMAGE_NAME}-serverside"
SERVERSIDE_CONTAINER_NAME="${CONTAINER_NAME}-serverside"
# Note: IMAGE_NAME and CONTAINER_NAME are derived in platform file
