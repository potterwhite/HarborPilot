# =============================================================================
# SDK Configuration (Defaults)
# =============================================================================
INSTALL_SDK="false"

# CHIP_FAMILY: identifies the silicon family for SDK repository grouping.
# Multiple OS variants of the same chip (e.g. rk3568 + rk3568-ubuntu22) share
# the same GitLab team and SDK key — set CHIP_FAMILY to the bare chip name.
# Defaults to PRODUCT_NAME; override in platform file when PRODUCT_NAME
# includes an OS suffix (e.g. "rk3568-ubuntu22" → CHIP_FAMILY="rk3568").
CHIP_FAMILY="${PRODUCT_NAME}"

# SDK_INSTALL_PATH, SDK_GIT_REPO, SDK_GIT_KEY_FILE depend on CHIP_FAMILY — computed in platform file
