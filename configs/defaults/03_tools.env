# =============================================================================
# Development Tools Configuration (Defaults)
# =============================================================================
INSTALL_CUDA="false"
INSTALL_OPENCV="false"
INSTALL_HOST_CMAKE="true"
INSTALL_MAN_DOC="true"
INSTALL_DISTCC="false"
NPM_USE_CHINA_MIRROR="false"

# Tool versions
CONAN_VERSION=2.0.17
CMAKE_FORMAT_VERSION=0.6.13
PRE_COMMIT_VERSION=3.5.0
CUDA_VERSION=12.0
OPENCV_VERSION=4.9.0

# Toolchain installation flags
INSTALL_TOOLCHAIN="false"
# Offline packages configuration (离线包配置)
# Comment out to disable installation (注释掉以禁用安装)
GCC_OFFLINE_PACKAGE="gcc-arm-10.3-2021.07-x86_64-aarch64-none-linux-gnu.tar.gz"
GCC_OFFLINE_VERSION="10.3.0"
GCC_INSTALL_PATH="/usr/local"
