# =============================================================================
# Development Tools Configuration (Defaults)
# =============================================================================
INSTALL_CUDA="false"
INSTALL_OPENCV="false"
INSTALL_HOST_CMAKE="true"
INSTALL_MAN_DOC="true"
NPM_USE_CHINA_MIRROR="false"

# Tool versions
CONAN_VERSION=2.0.17
CMAKE_FORMAT_VERSION=0.6.13
PRE_COMMIT_VERSION=3.5.0
CUDA_VERSION=12.0
OPENCV_VERSION=4.9.0
