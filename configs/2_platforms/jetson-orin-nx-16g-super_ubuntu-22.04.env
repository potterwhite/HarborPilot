################################################################################
# File: configs/2_platforms/jetson-orin-nx-16g-super_ubuntu-22.04.env
#
# Description: Platform-specific overrides for jetson-orin-nx-16g-super_ubuntu-22.04 (ubuntu 22.04).
#              Only values that DIFFER from configs/1_defaults/*.env are listed.
#              All other settings are inherited from the defaults layer.
#
# Author: PotterWhite
# Created: 2026-06-25
# Last Modified: 2026-06-25
#
# Copyright (c) 2024 [PotterWhite]
# License: MIT
#
# Port: PORT_SLOT=7
#   → CLIENT_SSH_PORT=2179, GDB_PORT=2415 (auto-calculated)
#
################################################################################

# =============================================================================
# Platform Identity  [REQUIRED — no defaults]
# =============================================================================
CHIP_FAMILY="jetson"
# orin-nx-16g-super is a variant of jetson series SOC
CHIP_EXTRACT_NAME="orin-nx-16g-super"
OS_DISTRIBUTION="ubuntu"
OS_VERSION="22.04"
# OS_VERSION_ID: dots replaced by dashes — safe for PRODUCT_NAME / CONTAINER_NAME
# (docker compose project names forbid dots; image tags allow them but dash is consistent)
OS_VERSION_ID="22-04"
PRODUCT_NAME="${CHIP_FAMILY}-${CHIP_EXTRACT_NAME}_${OS_DISTRIBUTION}-${OS_VERSION_ID}"

# Derived from PRODUCT_NAME (keep in sync)
IMAGE_NAME="${PRODUCT_NAME}-dev-env"
LATEST_IMAGE_TAG=${PROJECT_VERSION}
CONTAINER_NAME=${PRODUCT_NAME}

# =============================================================================
# GitLab Server  [optional — set HAVE_GITLAB_SERVER=FALSE to skip]
# =============================================================================
HAVE_GITLAB_SERVER="TRUE"
GITLAB_SERVER_IP="192.168.3.67"
GITLAB_SERVER_PORT="80"

# =============================================================================
# Harbor Registry  [required for push/pull]
# =============================================================================
HARBOR_SERVER_IP="192.168.3.67"
HARBOR_SERVER_PORT="9000"
# REGISTRY_URL is computed in host config (Layer 3) — depends on host-specific IP.

# =============================================================================
# SDK  [auto-generated — only used when INSTALL_SDK=true]
# =============================================================================
SDK_GIT_KEY_FILE="SDK_${CHIP_FAMILY}_ED25519"
SDK_GIT_DEFAULT_BRANCH="main"
# SDK_GIT_REPO is computed in host config (Layer 3) — depends on GITLAB_SERVER_IP.

# =============================================================================
# Docker Volumes  [REQUIRED — no universal default]
# =============================================================================
HOST_VOLUME_DIR="/mnt/2tb_wd_purpleSurveillance_hdd/system-redirection/Development/docker/volumes/jetson"

# =============================================================================
# Extra Volume Mounts  [optional — 0..N indexed; contiguous from 0]
# =============================================================================
EXTRA_VOLUME_0="/home/james/syncthing/under-git-control/ObsidianVault/PARA-Vault/1_PROJECT/2025.18_Project_Helmsman:/volume_helmsman"

# =============================================================================
# Container Runtime  [ports auto-calculated from PORT_SLOT]
# =============================================================================
PORT_SLOT="7"
USE_NVIDIA_GPU="false"

# =============================================================================
# Proxy Overrides
# =============================================================================
HAS_PROXY="true"
HTTP_PROXY_IP="http://192.168.3.164:7890"
HTTPS_PROXY_IP="http://192.168.3.164:7890"
