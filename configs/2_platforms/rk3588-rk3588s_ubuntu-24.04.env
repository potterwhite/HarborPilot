################################################################################
# File: configs/2_platforms/rk3588s-ubuntu-24.env
#
# Description: Platform-specific overrides for rk3588s-ubuntu-24 (ubuntu 24.04).
#              Only values that DIFFER from configs/1_defaults/*.env are listed.
#              All other settings are inherited from the defaults layer.
#
# Author: PotterWhite
# Created: 2026-03-24
# Last Modified: 2026-06-18
#
# Copyright (c) 2024 [PotterWhite]
# License: MIT
#
# Port: PORT_SLOT=5
#   → CLIENT_SSH_PORT=2159, GDB_PORT=2395 (auto-calculated)
#
################################################################################

# =============================================================================
# Platform Identity  [REQUIRED — no defaults]
# =============================================================================
CHIP_FAMILY="rk3588"
# rk3588s is a variant of rk3588 series SOC
CHIP_EXTRACT_NAME="rk3588s"
OS_DISTRIBUTION="ubuntu"
OS_VERSION="24.04"
OS_VERSION_ID="24-04"
PRODUCT_NAME="${CHIP_FAMILY}-${CHIP_EXTRACT_NAME}_${OS_DISTRIBUTION}-${OS_VERSION_ID}"

# Derived from PRODUCT_NAME (keep in sync)
IMAGE_NAME="${PRODUCT_NAME}-dev-env"
LATEST_IMAGE_TAG=${PROJECT_VERSION}
CONTAINER_NAME=${PRODUCT_NAME}

# =============================================================================
# SDK  [auto-generated by create_platform.sh — only used when INSTALL_SDK=true]
# =============================================================================
SDK_GIT_KEY_FILE="SDK_${CHIP_FAMILY}_ED25519"
SDK_GIT_DEFAULT_BRANCH="main"

# =============================================================================
# Container Runtime  [ports auto-calculated from PORT_SLOT]
# =============================================================================
PORT_SLOT="5"

################################################################################
# All other settings are inherited from configs/1_defaults/*.env
# Host-specific overrides go in configs/3_hosts/<hostname>.env
################################################################################
