################################################################################
# File: configs/3_hosts/TEMPLATE.env.example
#
# Description: Host-level configuration template.
#              Copy this file to <your-hostname>.env and customize:
#
#                  cp TEMPLATE.env.example $(hostname).env
#
#              Only add values that DIFFER from your platform config.
#              If a variable is not set here, the platform value is used.
#
# Author: PotterWhite
# Created: 2026-06-18
#
# Copyright (c) 2024 [PotterWhite]
# License: MIT
#
################################################################################

# =============================================================================
# Network & Proxy  [network environment specific]
# =============================================================================

# Whether this host has proxy access (default: false)
# Set to "true" if behind a corporate proxy or firewall
# HAS_PROXY="true"

# Proxy server IP (only needed if HAS_PROXY=true)
# HTTP_PROXY_IP="192.168.3.67"
# HTTPS_PROXY_IP="192.168.3.67"

# Use China npm mirror for faster downloads in China (default: false)
# NPM_USE_CHINA_MIRROR="true"

# =============================================================================
# Server Connectivity  [which servers this host can reach]
# =============================================================================

# GitLab server (for SDK repos)
# Set HAVE_GITLAB_SERVER="FALSE" if this host cannot reach GitLab
# HAVE_GITLAB_SERVER="TRUE"
# GITLAB_SERVER_IP="192.168.3.67"
# GITLAB_SERVER_PORT="80"

# Harbor registry (for Docker images)
# Set HAVE_HARBOR_SERVER="FALSE" if this host cannot reach Harbor
# HARBOR_SERVER_IP="192.168.3.67"
# HARBOR_SERVER_PORT="9000"

# =============================================================================
# Hardware  [machine-specific hardware]
# =============================================================================

# Whether this host has NVIDIA GPU (default: false)
# USE_NVIDIA_GPU="true"

# Shared memory size (GPU workloads need more, default: 256m)
# CONTAINER_SHM_SIZE="1g"

# =============================================================================
# Volume Paths  [host filesystem paths]
# =============================================================================

# Docker volumes directory (host-specific path, no universal default)
# This MUST be set if not defined in your platform file
# HOST_VOLUME_DIR="/mnt/ssd/docker-volumes/${PRODUCT_NAME}"

# Extra volume mounts (0..N indexed, contiguous from 0)
# These are typically user-specific paths like notes, projects, etc.
# EXTRA_VOLUME_0="/home/username/notes:/volumes_notes"
# EXTRA_VOLUME_1="/home/username/projects:/volumes_projects"

################################################################################
# End of Host Configuration
################################################################################
