################################################################################
# File: configs/3_hosts/TEMPLATE.env.example
#
# Description: Host-level configuration template.
#              Copy this file to <your-hostname>.env and customize:
#
#                  cp TEMPLATE.env.example $(hostname).env
#
#              Only add values that DIFFER from your platform config.
#              If a variable is not set here, the platform value is used.
#
# Author: PotterWhite
# Created: 2026-06-18
#
# Copyright (c) 2024 [PotterWhite]
# License: MIT
#
################################################################################

# =============================================================================
# Platform Reference  [REQUIRED — determines which platform to load]
# =============================================================================
# This host's base platform (must match a file in configs/2_platforms/)
# The platform provides: chip identity, OS version, port slot, SDK config
# This host config then overrides platform values as needed.
# BASE_PLATFORM="rk3588-rk3588s_ubuntu-24.04"

# =============================================================================
# Network & Proxy  [network environment specific]
# =============================================================================

# Whether this host has proxy access (default: false)
# Set to "true" if behind a corporate proxy or firewall
# HAS_PROXY="true"

# Proxy server IP (only needed if HAS_PROXY=true)
# HTTP_PROXY_IP="192.168.3.67"
# HTTPS_PROXY_IP="192.168.3.67"

# Use China npm mirror for faster downloads in China (default: false)
# NPM_USE_CHINA_MIRROR="true"

# =============================================================================
# Server Connectivity  [which servers this host can reach]
# =============================================================================

# GitLab server (for SDK repos)
# Set HAVE_GITLAB_SERVER="FALSE" if this host cannot reach GitLab
# HAVE_GITLAB_SERVER="TRUE"
# GITLAB_SERVER_IP="192.168.3.67"
# GITLAB_SERVER_PORT="80"

# Harbor registry (for Docker images)
# Set HAVE_HARBOR_SERVER="FALSE" if this host cannot reach Harbor
# HARBOR_SERVER_IP="192.168.3.67"
# HARBOR_SERVER_PORT="9000"

# Registry URL — full path to the Harbor project for this platform's images.
# Auto-derived from HARBOR_SERVER_IP + HARBOR_SERVER_PORT + CHIP_FAMILY (from platform).
# Must be defined here (Layer 3) because it depends on the host's server IP.
# REGISTRY_URL="${HARBOR_SERVER_IP}:${HARBOR_SERVER_PORT}/team_${CHIP_FAMILY}"

# =============================================================================
# SDK Overrides  [only needed when INSTALL_SDK=true in defaults]
# =============================================================================
# SDK_INSTALL_PATH is set in defaults (Layer 1) — do not override.
# SDK_GIT_KEY_FILE and SDK_GIT_DEFAULT_BRANCH are set in the platform file (Layer 2).
#
# SDK_GIT_REPO must be defined here (Layer 3) because it depends on
# GITLAB_SERVER_IP, which is host-specific. The formula uses variables from
# Layer 2 (CHIP_FAMILY, PRODUCT_NAME) which are already in the environment
# when Layer 3 is sourced.
# SDK_GIT_REPO="git@${GITLAB_SERVER_IP}:team_${CHIP_FAMILY}/${PRODUCT_NAME}_sdk.git"
#
# Override SDK_GIT_KEY_FILE when the SSH key type is not ED25519.
# SDK_GIT_KEY_FILE="SDK_rk3588_RSA"
#
# Override SDK_GIT_DEFAULT_BRANCH when the platform default branch is wrong.
# SDK_GIT_DEFAULT_BRANCH="main"

# =============================================================================
# Hardware  [machine-specific hardware]
# =============================================================================

# Whether this host has NVIDIA GPU (default: false)
# USE_NVIDIA_GPU="true"

# Shared memory size (GPU workloads need more, default: 256m)
# CONTAINER_SHM_SIZE="1g"

# =============================================================================
# Build Options  [per-stage feature toggles]
# =============================================================================
# Override defaults to skip or enable specific build stages.
# Defaults are defined in configs/1_defaults/ (Layer 1).
# Only set values here to CHANGE the default behavior.

# ── stage_2nd_tools: AI Coding Tools ─────────────────────────────────────────
# Installed after Node.js. Set to "false" to skip.
# Dependencies: INSTALL_CODEX and INSTALL_CLAUDE_CODE require Node.js/npm.
# INSTALL_CODEX="false"
# INSTALL_CLAUDE_CODE="false"
# INSTALL_OPENCODE="false"

# =============================================================================
# Volume Paths  [host filesystem paths]
# =============================================================================

# Docker volumes directory (host-specific path, no universal default)
# This MUST be set if not defined in your platform file
# HOST_VOLUME_DIR="/mnt/ssd/docker-volumes/${PRODUCT_NAME}"

# Extra volume mounts (0..N indexed, contiguous from 0)
# These are typically user-specific paths like notes, projects, etc.
# EXTRA_VOLUME_0="/home/username/notes:/volumes_notes"
# EXTRA_VOLUME_1="/home/username/projects:/volumes_projects"

################################################################################
# End of Host Configuration
################################################################################
