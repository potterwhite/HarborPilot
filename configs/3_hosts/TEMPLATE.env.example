################################################################################
# File: configs/3_hosts/TEMPLATE.env.example
#
# Description: Host-level configuration template.
#              Copy this file to <your-hostname>.env and customize:
#
#                  cp TEMPLATE.env.example $(hostname).env
#
#              Only add values that DIFFER from your platform config.
#              If a variable is not set here, the platform value is used.
#
#              Variables are ordered to match the wizard (create-config --host).
#              Each entry shows its question number for easy cross-reference.
#
# Author: PotterWhite
# Created: 2026-06-18
#
# Copyright (c) 2024 [PotterWhite]
# License: MIT
#
################################################################################

# ── Platform (set during Step 1 platform selection) ──────────────────────────

# BASE_PLATFORM="rk3588-rk3588s_ubuntu-24.04"

# ── Q1: Volume Directory ────────────────────────────────────────────────────

# Q1: Docker volumes directory on this host (no universal default)
# HOST_VOLUME_DIR="/mnt/ssd/docker-volumes/${PRODUCT_NAME}"

# ── Q2-Q3: Harbor Server ────────────────────────────────────────────────────

# Q2: Harbor server IP (for pulling pre-built images)
# HARBOR_SERVER_IP="192.168.3.67"

# Q3: Harbor server port (default: 9000)
# HARBOR_SERVER_PORT="9000"

# Auto-derived
# REGISTRY_URL= ${HARBOR_SERVER_IP}:${HARBOR_SERVER_PORT}/team_${CHIP_FAMILY}

# ── Q4: GitLab Server ───────────────────────────────────────────────────────

# Q4: Is GitLab server reachable? (default: false)
# HAVE_GITLAB_SERVER="TRUE"

# Q4a: GitLab server IP (asked only if Q4=y, default: same as Harbor IP)
# GITLAB_SERVER_IP="192.168.3.67"

# Q4b: GitLab server port (asked only if Q4=y, default: 80)
# GITLAB_SERVER_PORT="80"

# ── Q5: Proxy ───────────────────────────────────────────────────────────────

# Q5: Behind firewall that blocks Docker registry? (default: false)
# HAS_PROXY="true"

# Q5a: HTTP proxy IP (asked only if Q5=y, default: same as Harbor IP)
# HTTP_PROXY_IP="192.168.3.67"

# Q5b: HTTPS proxy IP (asked only if Q5=y, default: same as HTTP proxy)
# HTTPS_PROXY_IP="192.168.3.67"

# ── Q6-Q7: GPU ──────────────────────────────────────────────────────────────

# Q6: NVIDIA GPU? (default: false)
# USE_NVIDIA_GPU="true"

# Q7: SHM size (asked only if Q6=y; auto-sets 8g when GPU=true, 256m otherwise)
# CONTAINER_SHM_SIZE="1g"

# ── Q8-Q9: Container Settings ───────────────────────────────────────────────

# Q8: Host network mode? (default: host)
# NETWORK_MODE="host"

# Q9: Auto-restart container on boot? (default: unless-stopped)
# CONTAINER_RESTART_POLICY="unless-stopped"

# ── Q10-Q11: Build Toggles ──────────────────────────────────────────────────

# Q10: Install CUDA toolkit? (default: false)
# INSTALL_CUDA="false"

# Q11: Install OpenCV? (default: false)
# INSTALL_OPENCV="false"

# ── Q12: npm Mirror ─────────────────────────────────────────────────────────

# Q12: Use China npm mirror? (default: false)
# NPM_USE_CHINA_MIRROR="true"

# ── Q13: Extra Volumes ──────────────────────────────────────────────────────

# Q13: Extra volume mounts (0..N indexed, contiguous from 0)
# EXTRA_VOLUME_0="/home/username/notes:/volumes_notes"
# EXTRA_VOLUME_1="/home/username/projects:/volumes_projects"

# ── Q14-Q15: SDK ────────────────────────────────────────────────────────────

# Q14: Install SDK? (default: false)
# INSTALL_SDK="true"

# Q15a: SDK git repo (auto-derived from GitLab IP + platform identity)
# SDK_GIT_REPO="git@${GITLAB_SERVER_IP}:team_${CHIP_FAMILY}/${PRODUCT_NAME}_sdk.git"

# Q15b: SSH key file (default: SDK_${CHIP_FAMILY}_ED25519)
# SDK_GIT_KEY_FILE="SDK_rk3588_RSA"

# Q15c: SDK git branch (default: main)
# SDK_GIT_DEFAULT_BRANCH="main"

# SDK_INSTALL_PATH — set in defaults (Layer 1), do not override

# ── Additional Toggles  [not asked by wizard — override if needed] ──────────
# Defaults are defined in configs/1_defaults/ (Layer 1).
# Only set values here to CHANGE the default behavior.

# AI Coding Tools
# INSTALL_CODEX="false"
# INSTALL_CLAUDE_CODE="false"
# INSTALL_OPENCODE="false"

# Component Toggles
# INSTALL_DEV_TOOLS="false"        # gdb, valgrind, clang, cppcheck, minicom, repo
# INSTALL_MINICOM_CONFIG="false"   # minicom serial port config files
# INSTALL_DOC_TOOLS="false"        # doxygen, graphviz
# INSTALL_VCS_TOOLS="false"        # bash-completion (git/git-lfs always on)
# INSTALL_KERNEL_TOOLS="false"     # dtc, bison, flex, texinfo, ctags, cscope, ncurses
# INSTALL_PYTHON_PACKAGES="false"  # cmake-format, pre-commit

################################################################################
# End of Host Configuration
################################################################################
