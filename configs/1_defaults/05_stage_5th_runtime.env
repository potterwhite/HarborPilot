################################################################################
# File: configs/1_defaults/05_stage_5th_runtime.env
#
# Description: Default workspace, volumes, Samba, and container runtime
#              configuration for stage_5th_final. Covers directory layout,
#              volume mounts, Samba shares, and container runtime settings.
#              Override in platform (Layer 2) or host (Layer 3) config.
#
# Dockerfile stage: stage_5th_final
# Scripts: stage_5_final/scripts/setup_workspace.sh,
#          stage_5_final/scripts/entrypoint.sh
#
# Author: PotterWhite
# Created: 2026-03-18
#
# Copyright (c) 2024 [PotterWhite]
# License: MIT
################################################################################

# =============================================================================
# Workspace Configuration (Defaults)
# =============================================================================
WORKSPACE_ROOT="/development"
WORKSPACE_1ST_SOURCE_SUBDIR="${WORKSPACE_ROOT}/i_src"
WORKSPACE_2ND_BUILD_SUBDIR="${WORKSPACE_ROOT}/ii_build"
WORKSPACE_3RD_LOGS_SUBDIR="${WORKSPACE_ROOT}/iii_logs"
WORKSPACE_4TH_TEMP_SUBDIR="${WORKSPACE_ROOT}/iv_temp"
WORKSPACE_5TH_DOCS_SUBDIR="${WORKSPACE_ROOT}/v_docs"
WORKSPACE_6TH_TOOLS_SUBDIR="${WORKSPACE_ROOT}/vi_tools"
WORKSPACE_DEFAULT_PROJECT_NAME="embedded_project"
WORKSPACE_DEFAULT_BUILD_TYPE="Debug"
WORKSPACE_BUILD_THREADS="4"
WORKSPACE_ENABLE_AUTO_SAVE="true"
WORKSPACE_ENABLE_ERROR_REPORTING="true"
WORKSPACE_LOG_LEVEL="INFO"
WORKSPACE_ENABLE_VSC_INTEGRATION="false"
WORKSPACE_ENABLE_REMOTE_DEBUG="true"
WORKSPACE_DEBUG_PORT="3000"

# =============================================================================
# Docker Volumes Configuration (Defaults)
# =============================================================================
VOLUMES_ROOT="${WORKSPACE_ROOT}"
# HOST_VOLUME_DIR: the host path mounted into the container.
# This has no universal default — set it in configs/2_platforms/<platform>.env
# HOST_VOLUME_DIR="/path/to/your/host/volume"

# Extra volume mounts  [optional, 0..N per platform]
# Use EXTRA_VOLUME_0, EXTRA_VOLUME_1, … in your platform .env file to mount
# additional host directories into the container at runtime.
#
# Format:  EXTRA_VOLUME_N="<host_absolute_path>:<container_absolute_path>"
#
# Examples (in configs/2_platforms/<platform>.env):
#   EXTRA_VOLUME_0="/mnt/host-a:/volumes_container-a"
#   EXTRA_VOLUME_1="/mnt/data:/data"
#
# Rules:
#   - Indices MUST be contiguous starting from 0; scanning stops at the first
#     missing index.
#   - Omit all EXTRA_VOLUME_* lines if no extra mounts are needed.
#   - Do NOT define any EXTRA_VOLUME_* here in the defaults file; each
#     platform declares only what it needs.
#
# These are injected into docker-compose.yaml by 04_compose_generator.sh.

# =============================================================================
# Samba Configuration (Defaults)
# =============================================================================
SAMBA_SERVER_IP=""
SAMBA_PUBLIC_ACCOUNT_NAME="sambashare"
SAMBA_PUBLIC_ACCOUNT_PASSWORD="sambashare"
SAMBA_PRIVATE_ACCOUNT_NAME="sambaadmin"
SAMBA_PRIVATE_ACCOUNT_PASSWORD=""
SAMBA_FILE_MODE="0777"
SAMBA_DIR_MODE="0777"
ENABLE_VSC_INTEGRATION="false"

# =============================================================================
# Container Runtime Configuration (Defaults)
# =============================================================================
ENABLE_SSH="true"
# CLIENT_SSH_PORT: derived from PORT_SLOT via scripts/port_calc.sh
ENABLE_SYSLOG="true"
ENABLE_GDB_SERVER="true"
# GDB_PORT:        derived from PORT_SLOT via scripts/port_calc.sh
ENABLE_CORE_DUMPS="true"
CORE_PATTERN="${WORKSPACE_3RD_LOGS_SUBDIR}/core-%e-%p-%t"
USE_NVIDIA_GPU="false"

# =============================================================================
# Container Compose Overrides (used by ubuntu_only_entrance.sh)
# =============================================================================
CONTAINER_RESTART_POLICY="unless-stopped"
CONTAINER_PRIVILEGED="true"
CONTAINER_SERIAL_DEVICE="/dev/ttyUSB0"
CONTAINER_SHM_SIZE="8g"
NVIDIA_VISIBLE_DEVICES="all"
NVIDIA_DRIVER_CAPABILITIES="all"
