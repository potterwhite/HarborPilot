# =============================================================================
# SDK Configuration (Defaults)
# =============================================================================
INSTALL_SDK="false"

# SDK_INSTALL_PATH: where the SDK is mounted inside the container.
# This is a repo convention — same across all platforms. Do not override.
SDK_INSTALL_PATH="${WORKSPACE_ROOT}/sdk"

# CHIP_FAMILY: identifies the silicon family for SDK repository grouping.
# Multiple OS variants of the same chip (e.g. rk3568 + rk3568-ubuntu22) share
# the same GitLab team and SDK key — set CHIP_FAMILY to the bare chip name.
# Defaults to PRODUCT_NAME; override in platform file when PRODUCT_NAME
# includes an OS suffix (e.g. "rk3568-ubuntu22" → CHIP_FAMILY="rk3568").
CHIP_FAMILY="${PRODUCT_NAME}"

# SDK_GIT_REPO, SDK_GIT_KEY_FILE, SDK_GIT_DEFAULT_BRANCH depend on CHIP_FAMILY
# and are computed in each platform file (Layer 2). Host config (Layer 3) can
# override them when GITLAB_SERVER_IP or SSH key type differs from defaults.
