################################################################################
# File: configs/1_defaults/01_stage_1st_base.env
#
# Description: Default base system configuration for stage_1st_base.
#              Sets up OS, user accounts, timezone, and base packages.
#              Override in platform (Layer 2) or host (Layer 3) config.
#
# Dockerfile stage: stage_1st_base
# Scripts: stage_1_base/scripts/setup_base.sh
#
# Author: PotterWhite
# Created: 2026-03-18
#
# Copyright (c) 2024 [PotterWhite]
# License: MIT
################################################################################

# =============================================================================
# Base Configuration (Defaults)
# =============================================================================
OS_DISTRIBUTION="ubuntu"
OS_VERSION="22.04"
# OS_VERSION with dots replaced by dashes — safe for use in PRODUCT_NAME / CONTAINER_NAME
# (docker compose project names forbid dots; image tags allow them but dash is consistent)
OS_VERSION_ID="22-04"

# ── Platform Identity  [MUST be overridden in Layer 2 (platform config)] ─────
# These are placeholder defaults — each platform defines its own identity.
PRODUCT_NAME="generic-dev-env"          # Override in Layer 2 (e.g. "rk3588_ubuntu-24.04")
IMAGE_NAME="${PRODUCT_NAME}-dev-env"    # Derived from PRODUCT_NAME; override if needed
CONTAINER_NAME="${PRODUCT_NAME}"        # Derived from PRODUCT_NAME; override if needed
CHIP_FAMILY="generic"                   # Override in Layer 2 (e.g. "rk3588", "jetson")
CHIP_EXTRACT_NAME=""                    # Override in Layer 2 (e.g. "orin-nx-16g-super")
# ─────────────────────────────────────────────────────────────────────────────

DEV_USERNAME="developer"
DEV_GROUP="developer"
DEV_USER_PASSWORD="123"
DEV_USER_ROOT_PASSWORD="123"
DEV_UID="1000"
DEV_GID="1000"
TIMEZONE="Asia/Hong_Kong"
DEBIAN_FRONTEND="noninteractive"
