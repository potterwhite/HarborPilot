################################################################################
# File: configs/1_defaults/01_stage_1st_base.env
#
# Description: Default base system configuration for stage_1st_base.
#              Sets up OS, user accounts, timezone, and base packages.
#              Override in platform (Layer 2) or host (Layer 3) config.
#
# Dockerfile stage: stage_1st_base
# Scripts: stage_1_base/scripts/setup_base.sh
#
