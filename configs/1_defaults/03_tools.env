# =============================================================================
# Development Tools Configuration (Defaults)
# =============================================================================
INSTALL_CUDA="false"
INSTALL_OPENCV="false"
INSTALL_HOST_CMAKE="true"
INSTALL_MAN_DOC="true"
NPM_USE_CHINA_MIRROR="false"

# Tool versions
CONAN_VERSION=2.0.17
CMAKE_FORMAT_VERSION=0.6.13
PRE_COMMIT_VERSION=3.5.0
CUDA_VERSION=12.0
OPENCV_VERSION=4.9.0

# =============================================================================
# AI Coding Tools  (installed after Node.js in the ninth stage)
# =============================================================================
# Set to "true" to install, "false" to skip.
# Dependencies: INSTALL_CODEX and INSTALL_CLAUDE_CODE require Node.js/npm.
# Override in host config (Layer 3) to disable individual tools.

INSTALL_CODEX="true"
INSTALL_CLAUDE_CODE="true"
INSTALL_OPENCODE="true"
