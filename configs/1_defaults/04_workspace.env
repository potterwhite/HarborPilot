# =============================================================================
# Workspace Configuration (Defaults)
# =============================================================================
WORKSPACE_ROOT="/development"
WORKSPACE_1ST_SOURCE_SUBDIR="${WORKSPACE_ROOT}/i_src"
WORKSPACE_2ND_BUILD_SUBDIR="${WORKSPACE_ROOT}/ii_build"
WORKSPACE_3RD_LOGS_SUBDIR="${WORKSPACE_ROOT}/iii_logs"
WORKSPACE_4TH_TEMP_SUBDIR="${WORKSPACE_ROOT}/iv_temp"
WORKSPACE_5TH_DOCS_SUBDIR="${WORKSPACE_ROOT}/v_docs"
WORKSPACE_6TH_TOOLS_SUBDIR="${WORKSPACE_ROOT}/vi_tools"
WORKSPACE_DEFAULT_PROJECT_NAME="embedded_project"
WORKSPACE_DEFAULT_BUILD_TYPE="Debug"
WORKSPACE_BUILD_THREADS="4"
WORKSPACE_ENABLE_AUTO_SAVE="true"
WORKSPACE_ENABLE_ERROR_REPORTING="true"
WORKSPACE_LOG_LEVEL="INFO"
WORKSPACE_ENABLE_VSC_INTEGRATION="false"
WORKSPACE_ENABLE_REMOTE_DEBUG="true"
WORKSPACE_DEBUG_PORT="3000"
