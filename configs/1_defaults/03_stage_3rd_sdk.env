################################################################################
# File: configs/1_defaults/03_stage_3rd_sdk.env
#
# Description: Default registry and SDK configuration for stage_3rd_sdk.
#              Covers server connectivity (GitLab, Harbor) and SDK setup.
#              Override in platform (Layer 2) or host (Layer 3) config.
#
# Dockerfile stage: stage_3rd_sdk
# Scripts: stage_3_sdk/scripts/install_sdk.sh
#
# Author: PotterWhite
# Created: 2026-03-18
#
# Copyright (c) 2024 [PotterWhite]
# License: MIT
################################################################################

# =============================================================================
# Registry Configuration (Defaults)
# =============================================================================
HAVE_GITLAB_SERVER="TRUE"
GITLAB_SERVER_IP="192.168.3.67"
GITLAB_SERVER_PORT="80"

HAVE_HARBOR_SERVER="TRUE"
HARBOR_SERVER_IP="192.168.3.67"
HARBOR_SERVER_PORT="9000"

# ── Registry URL  [MUST be overridden in Layer 2/3] ─────────────────────────
# Placeholder — no universal default. Depends on HARBOR_SERVER_IP + PORT + CHIP_FAMILY.
# Set in platform (Layer 2) or host (Layer 3) config.
REGISTRY_URL=""
# ─────────────────────────────────────────────────────────────────────────────

# =============================================================================
# SDK Configuration (Defaults)
# =============================================================================
INSTALL_SDK="false"

# SDK_INSTALL_PATH: where the SDK is mounted inside the container.
# This is a repo convention — same across all platforms. Do not override.
SDK_INSTALL_PATH="${WORKSPACE_ROOT}/sdk"

# ── SDK Git Repo  [MUST be overridden in Layer 2/3 when INSTALL_SDK=true] ────
# These are placeholder defaults — platform/host config must set the real values.
SDK_GIT_REPO=""                             # Override in Layer 2/3 (e.g. "git@192.168.3.67:team_jetson/jetson_sdk.git")
SDK_GIT_KEY_FILE="SDK_${CHIP_FAMILY}_ED25519"  # Default ED25519 key; override if using RSA
SDK_GIT_DEFAULT_BRANCH="main"               # Override if platform default branch differs
# ─────────────────────────────────────────────────────────────────────────────
