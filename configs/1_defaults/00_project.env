PROJECT_COPYRIGHT="© 2025 [PotterWhite] All Rights Reserved"
PROJECT_LICENSE="MIT"
PROJECT_VERSION="$VERSION"

# CI will write the date automatically
PROJECT_RELEASE_DATE=2026-06-11
SDK_VERSION="1.1.2"
