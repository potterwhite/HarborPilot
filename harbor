#!/bin/bash
################################################################################
# Script Name: harbor
# Description: Build multi-stage Docker image and push to registry
# Usage: ./harbor [COMMAND] [--host=<name>] [--help]
#
# Author: @PotterWhite
# created date: 2024-11-28
# last modified: 2025-06-29
################################################################################

set -e
if [[ "${V}" == "1" ]]; then
    set -x
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

################################################################################
# Parse CLI arguments
################################################################################
CLI_HOST=""
CLI_COMMAND=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        image-build|container-start|container-stop|container-status|container-remove|image-list)
            CLI_COMMAND="$1"
            shift
            ;;
        --host=*)
            CLI_HOST="${1#*=}"
            shift
            ;;
        --host)
            CLI_HOST="$2"
            shift 2
            ;;
        -h|--help)
            cat "${SCRIPT_DIR}/scripts/help.txt"
            exit 0
            ;;
        *)
            echo "Unknown argument: $1"
            echo "Usage: ./harbor [COMMAND] [--host=<name>] [--help]"
            exit 1
            ;;
    esac
done

################################################################################
# Load modules
################################################################################
source "${SCRIPT_DIR}/scripts/libs/common/utils.sh"
source "${SCRIPT_DIR}/scripts/libs/common/ui.sh"
source "${SCRIPT_DIR}/scripts/libs/config.sh"
source "${SCRIPT_DIR}/scripts/libs/build.sh"
source "${SCRIPT_DIR}/scripts/libs/package.sh"

################################################################################
# Main function to orchestrate the entire build process
################################################################################
main() {
    SECONDS=0
    echo "HarborPilot started at:"
    echo "###################################"
    echo "#   $(LC_ALL=C date +%a\ %b%d.%Y\ %H:%M:%S)"
    echo "###################################"

    BUILD_SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
    BUILD_SCRIPT_DIR="$(dirname ${BUILD_SCRIPT_PATH})"
    TOP_ROOT_DIR="${BUILD_SCRIPT_DIR}"
    TOP_CONFIGS_DIR="${TOP_ROOT_DIR}/configs"
    # src env means they are the original files
    PLATFORM_ENV_SRC_DIR="${TOP_CONFIGS_DIR}/2_platforms"
    # Legacy fallback (only used when host config has no BASE_PLATFORM)
    PLATFORM_ENV_DEST_PATH="${TOP_CONFIGS_DIR}/2_platforms/.env"

    ##################################################################
    # Check dependencies
    ##################################################################
    if ! _check_dependencies; then
        echo "Error: Missing required dependencies"
        exit 1
    fi

    if ! _check_docker_daemon; then
        echo "Error: Docker daemon is not running"
        exit 1
    fi

    ##################################################################
    # CLI mode: skip interactive menu entirely
    ##################################################################
    if [ -n "${CLI_COMMAND}" ]; then
        case "${CLI_COMMAND}" in
            image-build)
                _run_build_push
                exit $?
                ;;
            container-start)
                _run_container start
                exit $?
                ;;
            container-stop)
                _run_container stop
                exit $?
                ;;
            container-status)
                _run_container status
                exit $?
                ;;
            container-remove)
                _run_container remove
                exit $?
                ;;
            image-list)
                _run_image_list
                exit $?
                ;;
        esac
    fi

    ##################################################################
    # Top-level menu: choose action before platform selection
    ##################################################################
    while true; do
        _HARBOR_MODE="build"
        0_show_main_menu

        if [ "${_HARBOR_MODE}" = "config" ]; then
            _show_config_menu
            # If user built from config menu, proceed; otherwise show main menu again
            if [ "${_HARBOR_MODE}" = "build" ]; then
                break
            fi
            continue
        fi

        if [ "${_HARBOR_MODE}" = "container" ]; then
            _show_container_menu
            continue
        fi

        break
    done

    ##################################################################
    # Host/Platform selection
    #   build mode   → select host (which determines platform via BASE_PLATFORM)
    #   package mode → select platform directly
    ##################################################################
    _HARBOR_SKIP_BUILD=0
    if [ "${_HARBOR_MODE}" = "build" ]; then
        _run_build_push
        return $?
    elif [ "${_HARBOR_MODE}" = "package" ]; then
        while true; do
            if _pick_platform; then
                break
            fi
        done
        BASE_PLATFORM="${TARGET_PLATFORM}"
        # Load defaults first (PROJECT_VERSION, REGISTRY_URL, etc.)
        _load_layer1_defaults
        # Then overlay platform config
        local platform_env="${TOP_CONFIGS_DIR}/2_platforms/${BASE_PLATFORM}.env"
        if [ -f "${platform_env}" ]; then
            source "${platform_env}"
        else
            echo "Error: Platform config not found: ${platform_env}"
            return 1
        fi
    fi

    ##################################################################
    # Validate configuration
    ##################################################################
    if ! _validate_config; then
        echo "Error: Configuration validation failed"
        exit 1
    fi

    ##################################################################
    # Dispatch: package mode exits early; build mode continues
    ##################################################################
    if [ "${_HARBOR_MODE}" = "package" ]; then
        7_package_handover || exit 1
        local duration=$SECONDS
        echo "Total execution time: $((duration / 3600))h $((duration % 3600 / 60))m $((duration % 60))s"
        return 0
    fi
}

# Execute main function
main "$@"
