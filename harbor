# Helper function to tag a single image
# Arguments:
#   $1 - Image name
#   $2 - Source tag
#   $3 - Target tag
# Returns:
#   0 on success, 1 on failure
################################################################################
_tag_single_image() {
    # local image_name="$1"
    # local source_tag="$2"
    # local target_tag="$3"
    # local full_source="${image_name}:${source_tag}"
    # local full_target="${REGISTRY_URL}/${image_name}:${target_tag}"
    local source="${1}"
