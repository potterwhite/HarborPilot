#!/bin/bash
################################################################################
# Script Name: harbor
# Description: Build multi-stage Docker image and push to registry
# Usage: ./harbor
#
# Author: @PotterWhite
# created date: 2024-11-28
# last modified: 2025-06-29
################################################################################

set -e
if [[ "${V}" == "1" ]]; then
    set -x
fi

################################################################################
# Parse CLI arguments
################################################################################
CLI_HOST=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --host)
            CLI_HOST="$2"
            shift 2
            ;;
        *)
            echo "Unknown argument: $1"
            echo "Usage: ./harbor [--host <host-config-name>]"
            exit 1
            ;;
    esac
done

################################################################################
# Resolve script directory and load modules
################################################################################
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Load all modules
source "${SCRIPT_DIR}/scripts/lib/ui.sh"
source "${SCRIPT_DIR}/scripts/lib/config.sh"
source "${SCRIPT_DIR}/scripts/lib/build.sh"
source "${SCRIPT_DIR}/scripts/lib/utils.sh"

################################################################################
# Main function to orchestrate the entire build process
################################################################################
main() {
    SECONDS=0
    echo "HarborPilot started at:"
    echo "###################################"
    echo "#   $(LC_ALL=C date +%a\ %b%d.%Y\ %H:%M:%S)"
    echo "###################################"

    BUILD_SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
    BUILD_SCRIPT_DIR="$(dirname ${BUILD_SCRIPT_PATH})"
    TOP_ROOT_DIR="${BUILD_SCRIPT_DIR}"
    TOP_CONFIGS_DIR="${TOP_ROOT_DIR}/configs"
    HANDOVER_DIR="${TOP_ROOT_DIR}/project_handover"
    # src env means they are the original files
    PLATFORM_ENV_SRC_DIR="${TOP_CONFIGS_DIR}/2_platforms"
    # dest env means destination files, which are used for runtime
    PLATFORM_ENV_DEST_PATH="${HANDOVER_DIR}/.env"

    ##################################################################
    # Check dependencies
    ##################################################################
    if ! _check_dependencies; then
        echo "Error: Missing required dependencies"
        exit 1
    fi

    if ! _check_docker_daemon; then
        echo "Error: Docker daemon is not running"
        exit 1
    fi

    ##################################################################
    # Top-level menu: choose action before platform selection
    ##################################################################
    while true; do
        _HARBOR_MODE="build"
        0_show_main_menu

        if [ "${_HARBOR_MODE}" = "config" ]; then
            _show_config_menu
            # If user built from config menu, proceed; otherwise show main menu again
            if [ "${_HARBOR_MODE}" = "build" ]; then
                break
            fi
            continue
        fi

        break
    done

    ##################################################################
    # Host configuration (build and package modes need it)
    ##################################################################
    _HARBOR_SKIP_BUILD=0
    if [ "${_HARBOR_MODE}" = "build" ] || [ "${_HARBOR_MODE}" = "package" ]; then
        if [ -n "${CLI_HOST}" ]; then
            _load_host_config "${CLI_HOST}"
        else
            _select_host_config
        fi
    fi

    # User chose not to build after creating host config
    if [ "${_HARBOR_SKIP_BUILD}" = "1" ]; then
        return 0
    fi

    ##################################################################
    # Load all configuration layers
    ##################################################################
    _load_config_layers
    export HOST_CONFIG

    ##################################################################
    # Validate configuration
    ##################################################################
    if ! _validate_config; then
        echo "Error: Configuration validation failed"
        exit 1
    fi

    ##################################################################
    # Dispatch: package mode exits early; build mode continues
    ##################################################################
    if [ "${_HARBOR_MODE}" = "package" ]; then
        7_package_handover || exit 1
        local duration=$SECONDS
        echo "Total execution time: $((duration / 3600))h $((duration % 3600 / 60))m $((duration % 60))s"
        return 0
    fi

    0_check_registry_login || exit 1

    2_build_images || exit 1

    3_prepare_version_info || exit 1

    4_tag_images || exit 1

    5_push_images || exit 1

    6_cleanup_images || exit 1

    local duration=$SECONDS
    echo -e "\n=== Build Process Completed Successfully ==="
    echo "Total execution time: $((duration / 3600))h $((duration % 3600 / 60))m $((duration % 60))s"

    _print_next_steps
}

################################################################################
# 7. Package handover: create a self-contained client delivery tarball
#
# Archive layout (extracted to any directory):
#   <output>/
#   ├── project_handover/
#   │   ├── .env                     ← platform config (dereferenced)
#   │   ├── clientside/
#   │   │   └── ubuntu/              ← entrance script + 6 modules + harbor.crt
#   │   └── clientside/volumes/
#   │       └── .gitkeep
#   ├── configs/
#   │   └── 1_defaults/              ← 11 default .env files (including 00_project.env)
#   └── scripts/
#       └── port_calc.sh             ← port formula script
#
# The relative path from ubuntu/ to configs/1_defaults and scripts/ is preserved
# so 01_env_loader.sh resolves TOP_ROOT_DIR correctly after extraction.
################################################################################
7_package_handover() {
    echo -e "\n=== Packaging Client Handover ==="

    # Determine which platform to package from the current host config's BASE_PLATFORM
    local base_platform="${BASE_PLATFORM}"
    if [ -z "${base_platform}" ]; then
        echo "Error: BASE_PLATFORM not set. Cannot determine which platform to package."
        return 1
    fi

    local platform_env="${TOP_CONFIGS_DIR}/2_platforms/${base_platform}.env"
    if [ ! -f "${platform_env}" ]; then
        echo "Error: Platform config not found: ${platform_env}"
        return 1
    fi

    local version="${PROJECT_VERSION:-unknown}"
    local archive_name="${TOP_ROOT_DIR}/project_handover_${base_platform}_v${version}.tar.gz"

    echo "  Platform : ${base_platform}"
    echo "  Version  : ${version}"
    echo "  Output   : ${archive_name}"
    echo ""

    # ── Assemble archive in a temp staging directory ──────────────────────────
    local tmp_dir
    tmp_dir="$(mktemp -d)"
    local stage="${tmp_dir}/stage"

    # Directory structure expected by 01_env_loader.sh:
    #   project_handover/  (HANDOVER_DIR equivalent)
    #   configs/           (TOP_CONFIGS_DIR equivalent)
    #   scripts/           (shared scripts)
    mkdir -p "${stage}/project_handover/clientside/volumes"
    mkdir -p "${stage}/configs/1_defaults"
    mkdir -p "${stage}/configs/2_platforms"
    mkdir -p "${stage}/configs/3_hosts"
    mkdir -p "${stage}/scripts/lib"

    # 1. Copy ubuntu client directory
    cp -rL --no-dereference \
        "${HANDOVER_DIR}/clientside/ubuntu" \
        "${stage}/project_handover/clientside/ubuntu" 2>/dev/null || \
    cp -r "${HANDOVER_DIR}/clientside/ubuntu" \
          "${stage}/project_handover/clientside/ubuntu"
    rm -f "${stage}/project_handover/clientside/ubuntu/volumes"
    rm -f "${stage}/project_handover/clientside/ubuntu/docker-compose.yaml"

    # 2. Preserve volumes/.gitkeep placeholder
    touch "${stage}/project_handover/clientside/volumes/.gitkeep"

    # 3. Copy configs/1_defaults (all .env files)
    cp -r "${TOP_CONFIGS_DIR}/1_defaults/"*.env "${stage}/configs/1_defaults/"

    # 4. Copy only the selected platform config
    cp "${platform_env}" "${stage}/configs/2_platforms/${base_platform}.env"

    # 5. Copy host config template + README (not actual host configs)
    cp "${TOP_CONFIGS_DIR}/3_hosts/TEMPLATE.env.example" "${stage}/configs/3_hosts/"
    cp "${TOP_CONFIGS_DIR}/3_hosts/README.md" "${stage}/configs/3_hosts/"

    # 6. Copy shared scripts
    cp "${TOP_ROOT_DIR}/scripts/port_calc.sh" "${stage}/scripts/"
    cp "${TOP_ROOT_DIR}/scripts/lib/config.sh" "${stage}/scripts/lib/"

    # 7. Copy handover README (Chinese)
    if [ -f "${HANDOVER_DIR}/README_handover.md" ]; then
        cp "${HANDOVER_DIR}/README_handover.md" "${stage}/project_handover/"
    fi

    # ── Create the final tarball ─────────────────────────────────────────────
    tar -czf "${archive_name}" \
        -C "${stage}" \
        "project_handover" \
        "configs" \
        "scripts"

    # Clean up staging area
    rm -rf "${tmp_dir}"

    if [ ! -f "${archive_name}" ]; then
        echo "✗ Error: archive was not created."
        return 1
    fi

    local size
    size="$(du -sh "${archive_name}" | cut -f1)"

    echo ""
    echo "  ╔══════════════════════════════════════════════════════════════════╗"
    echo "  ║              HANDOVER PACKAGE CREATED SUCCESSFULLY              ║"
    echo "  ╠══════════════════════════════════════════════════════════════════╣"
    echo "  ║                                                                  ║"
    printf "  ║  File     : %-51s║\n" "$(basename "${archive_name}")"
    printf "  ║  Size     : %-51s║\n" "${size}"
    printf "  ║  Platform : %-51s║\n" "${base_platform}"
    printf "  ║  Version  : %-51s║\n" "${version}"
    echo "  ║                                                                  ║"
    echo "  ║  Deliver this tarball to the client Ubuntu host, then:          ║"
    echo "  ║                                                                  ║"
    printf "  ║    tar -xzf %-51s║\n" "$(basename "${archive_name}")"
    echo "  ║    cd project_handover/                                         ║"
    echo "  ║    ./clientside/ubuntu/ubuntu_only_entrance.sh start             ║"
    echo "  ║                                                                  ║"
    echo "  ╚══════════════════════════════════════════════════════════════════╝"
    echo ""
}

# Execute main function
main "$@"
