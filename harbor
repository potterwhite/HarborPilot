################################################################################
# 7. Package handover: create a self-contained client delivery tarball
#
# Archive layout (extracted to any directory):
#   <output>/
#   ├── project_handover/
#   │   ├── .env                     ← platform config (dereferenced)
#   │   ├── clientside/
#   │   │   └── ubuntu/              ← entrance script + 6 modules + harbor.crt
#   │   └── clientside/volumes/
#   │       └── .gitkeep
#   ├── configs/
#   │   └── 1_defaults/              ← 11 default .env files (including 00_project.env)
#   └── scripts/
#       └── port_calc.sh             ← port formula script
#
# The relative path from ubuntu/ to configs/1_defaults and scripts/ is preserved
# so 01_env_loader.sh resolves TOP_ROOT_DIR correctly after extraction.
################################################################################
7_package_handover() {
    echo -e "\n=== Packaging Client Handover ==="

    local timestamp
    timestamp="$(date +%m.%d.%Y_%H.%M.%S)"
    local archive_name="${TOP_ROOT_DIR}/project_handover_${PRODUCT_NAME}_${timestamp}.tar.gz"

    echo "  Platform : ${PRODUCT_NAME}"
    echo "  Output   : ${archive_name}"
    echo ""

    # Verify required source files exist
    if [ ! -f "${PLATFORM_ENV_DEST_PATH}" ]; then
        echo "✗ Error: .env symlink not found at ${PLATFORM_ENV_DEST_PATH}"
        return 1
    fi

    # ── Assemble archive in a temp staging directory ──────────────────────────
    # This avoids the GNU tar limitation that -r cannot append to compressed
    # archives, and gives us full control over the layout.
    local tmp_dir
    tmp_dir="$(mktemp -d)"
    local stage="${tmp_dir}/stage"

    # Mirror the directory structure that 01_env_loader.sh expects:
    #   ubuntu/ → ../../.. → stage/   (TOP_ROOT_DIR equivalent)
    #   ENTRY_DEFAULTS_DIR = TOP_ROOT_DIR/configs/1_defaults
    #   port_calc.sh       = TOP_ROOT_DIR/scripts/port_calc.sh
    mkdir -p "${stage}/project_handover/clientside/volumes"
    mkdir -p "${stage}/configs"
    mkdir -p "${stage}/scripts"

    # 1. Dereference .env (copy real file content)
    cp -L "${PLATFORM_ENV_DEST_PATH}" "${stage}/project_handover/.env"

    # 2. Copy ubuntu client directory (dereference symlinks with cp -rL)
    #    Exclude the volumes symlink inside ubuntu/
    cp -rL --no-dereference \
        "${HANDOVER_DIR}/clientside/ubuntu" \
        "${stage}/project_handover/clientside/ubuntu" 2>/dev/null || \
    cp -r "${HANDOVER_DIR}/clientside/ubuntu" \
          "${stage}/project_handover/clientside/ubuntu"
    # Remove the volumes symlink from the copied ubuntu dir (it's a local symlink)
    rm -f "${stage}/project_handover/clientside/ubuntu/volumes"
    # Remove docker-compose.yaml — it is dynamically generated at runtime by
    # 04_compose_generator.sh and should not be included in the delivery package
    rm -f "${stage}/project_handover/clientside/ubuntu/docker-compose.yaml"

    # 3. Preserve volumes/.gitkeep placeholder
    touch "${stage}/project_handover/clientside/volumes/.gitkeep"

    # 4. Copy configs/1_defaults (all .env files)
    cp -r "${TOP_ROOT_DIR}/configs/1_defaults" "${stage}/configs/1_defaults"

    # 5. Copy scripts/port_calc.sh
    cp "${TOP_ROOT_DIR}/scripts/port_calc.sh" "${stage}/scripts/port_calc.sh"

    # ── Create the final tarball from the staging directory ───────────────────
    tar -czf "${archive_name}" \
        -C "${stage}" \
        "project_handover" \
        "configs" \
        "scripts"

    # Clean up staging area
    rm -rf "${tmp_dir}"

    if [ ! -f "${archive_name}" ]; then
        echo "✗ Error: archive was not created."
        return 1
    fi

    local size
    size="$(du -sh "${archive_name}" | cut -f1)"

    echo ""
    echo "  ╔══════════════════════════════════════════════════════════════════╗"
    echo "  ║              HANDOVER PACKAGE CREATED SUCCESSFULLY              ║"
    echo "  ╠══════════════════════════════════════════════════════════════════╣"
    echo "  ║                                                                  ║"
    printf "  ║  File     : %-51s║\n" "$(basename "${archive_name}")"
    printf "  ║  Size     : %-51s║\n" "${size}"
    printf "  ║  Platform : %-51s║\n" "${PRODUCT_NAME}"
    echo "  ║                                                                  ║"
    echo "  ║  Deliver this tarball to the client Ubuntu host, then:          ║"
    echo "  ║                                                                  ║"
    printf "  ║    tar -xzf %-51s║\n" "$(basename "${archive_name}")"
    echo "  ║    cd project_handover/clientside/ubuntu/                        ║"
    echo "  ║    ./ubuntu_only_entrance.sh start                               ║"
    echo "  ║                                                                  ║"
    echo "  ╚══════════════════════════════════════════════════════════════════╝"
    echo ""
}

################################################################################
# 0. Pre-flight: verify docker registry login
# If HAVE_HARBOR_SERVER is TRUE, ensure the user is authenticated to the
# registry before we waste time building an image we cannot push.
# Returns:
#   0 if login is not required, or login is already valid
#   1 if user failed / declined to login
################################################################################
0_check_registry_login() {
    if [ "${HAVE_HARBOR_SERVER}" != "TRUE" ]; then
        echo "[Registry] HAVE_HARBOR_SERVER is not TRUE — skipping login check."
        return 0
    fi

    echo -e "\n[Registry] Checking Docker login status for ${REGISTRY_URL%%/*} ..."

    local registry_host="${HARBOR_SERVER_IP}:${HARBOR_SERVER_PORT}"

    # ------------------------------------------------------------------
    # Passive credential check — reads config.json only, no network call.
    # docker login writes an entry under .auths (plain creds) or registers
    # the host under .credHelpers (credential-helper mode); docker logout
    # removes it.  Either key present means the user has logged in.
    # ------------------------------------------------------------------
    local docker_config="${DOCKER_CONFIG:-${HOME}/.docker}/config.json"

    if [ -f "${docker_config}" ] && \
       grep -qF "\"${registry_host}\"" "${docker_config}" 2>/dev/null; then
        echo "[Registry] Already logged in to ${registry_host}."
        return 0
    fi

    # Credentials either missing or invalid — ask user to login now
    echo ""
    echo "  ╔══════════════════════════════════════════════════════════════════╗"
    echo "  ║  ACTION REQUIRED: Docker registry login                         ║"
    echo "  ║                                                                  ║"
    echo "  ║  You must log in to the Harbor registry before building,         ║"
    echo "  ║  otherwise the push step will fail.                              ║"
    echo "  ║                                                                  ║"
    echo "  ║  Registry: ${registry_host}"
    echo "  ║                                                                  ║"
    echo "  ║  Run:  docker login ${registry_host}                             ║"
    echo "  ╚══════════════════════════════════════════════════════════════════╝"
    echo ""
    read -p "  Press ENTER to run 'docker login ${registry_host}' now, or Ctrl+C to abort: "

    if docker login "${registry_host}"; then
        echo "[Registry] Login successful."
        return 0
    else
        echo "[Registry] Login failed. Aborting build."
        return 1
    fi
}

